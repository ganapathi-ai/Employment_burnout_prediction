# Database Configuration (from Neon Postgres)
# Get your free Neon DB at https://neon.tech
PGHOST=your-neon-host.neon.tech
PGDATABASE=neondb
PGUSER=neondb_owner
PGPASSWORD=your_neon_password_here
PGSSLMODE=require
PGCHANNELBINDING=require
DATABASE_URL=postgresql://neondb_owner:your_neon_password_here@your-neon-host.neon.tech/neondb?sslmode=require&channel_binding=require

# Weights & Biases (experiment tracking)
# Get your API key at https://wandb.ai/settings
WANDB_API_KEY=your_wandb_api_key_here
WANDB_ENTITY=your_wandb_entity_here
ENABLE_WANDB=true

# Model Paths (leave as-is for standard setup)
MODEL_PATH=models/best_model.joblib
PREPROCESSOR_PATH=models/preprocessor.joblib

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info

# Frontend Configuration
STREAMLIT_SERVER_PORT=8501
API_URL=http://localhost:8000

# Environment
ENVIRONMENT=development
DEBUG=False
