      "title": "🧠 Predictions & Model Health",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}]}, "unit": "short"}},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 1},
      "id": 1,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto"},
      "title": "Total High-Risk Predictions",
      "type": "stat",
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "predictions_total{risk_level=\"High\"}", "legendFormat": "High Risk", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}, "unit": "short"}},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 1},
      "id": 2,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto"},
      "title": "Total Low-Risk Predictions",
      "type": "stat",
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "predictions_total{risk_level=\"Low\"}", "legendFormat": "Low Risk", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "mappings": [{"options": {"0": {"color": "red", "index": 1, "text": "NOT LOADED"}, "1": {"color": "green", "index": 0, "text": "LOADED"}}, "type": "value"}], "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}, "unit": "short"}},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1},
      "id": 3,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto"},
      "title": "ML Model Status",
      "type": "stat",
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "model_loaded{job=\"burnout-api\"}", "legendFormat": "Model", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.01}, {"color": "red", "value": 0.05}]}, "unit": "percentunit"}},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1},
      "id": 4,
      "options": {"colorMode": "background", "graphMode": "area", "justifyMode": "center", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto"},
      "title": "5xx Error Rate",
      "type": "stat",
      "targets": [{"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(rate(api_requests_total{status=~\"5..\"}[5m])) / (sum(rate(api_requests_total[5m])) + 0.0001)", "legendFormat": "Error %", "refId": "A"}]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 2, "fillOpacity": 20, "gradientMode": "opacity"}, "unit": "short"},
        "overrides": [
          {"matcher": {"id": "byName", "options": "🔴 High Risk"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "🟢 Low Risk"}, "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]}
        ]
      },
      "gridPos": {"h": 9, "w": 14, "x": 0, "y": 5},
      "id": 10,
      "options": {"legend": {"calcs": ["mean", "sum", "lastNotNull"], "displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi", "sort": "desc"}},
      "title": "Live Prediction Rate — High vs Low Risk",
      "type": "timeseries",
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rate(predictions_total{risk_level=\"High\"}[1m])", "legendFormat": "🔴 High Risk", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rate(predictions_total{risk_level=\"Low\"}[1m])", "legendFormat": "🟢 Low Risk", "refId": "B"}
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"hideFrom": {"legend": false, "tooltip": false, "viz": false}}, "unit": "short"},
        "overrides": [
          {"matcher": {"id": "byName", "options": "High Risk"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "Low Risk"}, "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]}
        ]
      },
      "gridPos": {"h": 9, "w": 10, "x": 14, "y": 5},
      "id": 11,
      "options": {"displayLabels": ["percent", "name"], "legend": {"displayMode": "table", "placement": "bottom", "values": ["percent", "value"]}, "pieType": "donut", "tooltip": {"mode": "single"}},
      "title": "Prediction Distribution (Total)",
      "type": "piechart",
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "predictions_total{risk_level=\"High\"}", "legendFormat": "High Risk", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "predictions_total{risk_level=\"Low\"}", "legendFormat": "Low Risk", "refId": "B"}
      ]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14},
      "id": 101,
      "title": "🚨 Errors & Database Health",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 2, "fillOpacity": 10}, "unit": "reqps"},
        "overrides": [
          {"matcher": {"id": "byName", "options": "5xx Server Errors"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "4xx Client Errors"}, "properties": [{"id": "color", "value": {"fixedColor": "orange", "mode": "fixed"}}]}
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 15},
      "id": 20,
      "options": {"legend": {"calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "title": "Error Rate Over Time",
      "type": "timeseries",
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(rate(api_requests_total{status=~\"5..\"}[5m]))", "legendFormat": "5xx Server Errors", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "sum(rate(api_requests_total{status=~\"4..\"}[5m]))", "legendFormat": "4xx Client Errors", "refId": "B"}
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "custom": {"lineWidth": 2, "fillOpacity": 10}, "unit": "short"},
        "overrides": [
          {"matcher": {"id": "byName", "options": "DB Errors"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]},
          {"matcher": {"id": "byName", "options": "DB Success"}, "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]}
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 15},
      "id": 21,
      "options": {"legend": {"calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "title": "Database Operations (Success vs Errors)",
      "type": "timeseries",
      "targets": [
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rate(database_operations_total{status=\"success\"}[1m])", "legendFormat": "DB Success", "refId": "A"},
        {"datasource": {"type": "prometheus", "uid": "prometheus"}, "expr": "rate(database_operations_total{status=\"error\"}[1m])", "legendFormat": "DB Errors", "refId": "B"}
      ]
